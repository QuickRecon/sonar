	)
	(text "Sample calc for 2s lithium to 12v\n\nV_f = 0.38V\nV_out = 12v\nV_in = 6v (3.0v cutoff)\nV_sw = 0.5V (datasheet example)\nDuty cycle = (V_out + V_f - V_in)/(V_out+V_f-V_sw)\nDuty cycle = 0.537\n\nMax Load\nIsw = 1.4\nf = 1.6Mhz\nL= 10u\nIload = (1-duty)*(Isw - duty*(Vin-Vsw)/(2*f*L))\nIload = 0.605A\n\nMax solenoid wattage\nP = I*v\nP = 0.605*12\nP = 7.2W"
		(exclude_from_sim no)
		(at 165.862 60.452 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "d93c9c74-e7db-4e98-a1fc-6449f1aedfe9")
	)
	(text "Debug LEDs\n"
